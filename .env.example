# NSE Trading Intelligence Platform - Environment Variables

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/nse_trading

# API Keys
NEXT_PUBLIC_API_URL=http://localhost:3000/api
API_SECRET_KEY=your_secret_key_here

# OpenAI API
OPENAI_API_KEY=sk_your_openai_api_key

# Google Gemini API
GOOGLE_API_KEY=your_google_api_key

# Firebase (Optional)
FIREBASE_API_KEY=your_firebase_api_key
FIREBASE_PROJECT_ID=your_firebase_project_id

# NSE Data Source
NSE_DATA_API_KEY=your_nse_api_key
NSE_DATA_API_URL=https://api.nseindia.com

# Redis (Caching)
REDIS_URL=redis://localhost:6379

# Email Service
EMAIL_SERVICE_API_KEY=your_email_service_api_key
EMAIL_FROM=noreply@nsetrading.com

# Subscription & Payments
STRIPE_API_KEY=sk_test_your_stripe_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# Authentication
JWT_SECRET=your_jwt_secret_key_here
NEXTAUTH_SECRET=your_nextauth_secret_here
NEXTAUTH_URL=http://localhost:3000

# Analytics
GOOGLE_ANALYTICS_ID=UA_your_tracking_id
SENTRY_DSN=your_sentry_dsn

# Feature Flags
ENABLE_OPTIONS_CHAIN_ANALYZER=true
ENABLE_AI_SIGNALS=true
ENABLE_STOCK_SCREENER=true
ENABLE_INSTITUTIONAL_FLOW=true

# Node Environment
NODE_ENV=development
